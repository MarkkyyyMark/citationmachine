# Copy this file to `.env` and fill in your real key. `.env` is gitignored.
# Used by the credential drafter (Phase 4) for Claude web-search + drafting.
ANTHROPIC_API_KEY=sk-ant-...

# Phase 7 hardening — all optional; sensible defaults are baked in.
# Rate limits use the `limits` syntax ("10/hour", "10/hour;3/minute").
# RATE_CREDENTIALS=10/hour;3/minute   # billable Claude + web-search endpoint
# RATE_SCRAPE=30/minute               # live page fetch
# CREDENTIALS_TIMEOUT=90              # seconds before a hung draft is abandoned
